    "error_login_expired %@" : {
      "comment" : "A title for a view that shows an error message when the user's login has expired. The argument is the account key of the user whose login has expired.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sessie is verval vir %@. Meld asseblief weer aan."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "انتهت صلاحية الجلسة لـ %@. يرجى تسجيل الدخول مرة أخرى."
          }
        },
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Сесията е изтекла за %@. Моля, впишете се отново."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La sessió ha caducat per a %@. Torneu a iniciar la sessió."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Relace vypršela pro %@. Přihlaste se prosím znovu."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sessionen er udløbet for %@. Log venligst ind igen."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sitzung für %@ abgelaufen. Bitte erneut anmelden."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Η συνεδρία έληξε για %@. Παρακαλώ συνδεθείτε ξανά."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Login expired for %@"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La sesión ha caducado para %@. Inicie sesión de nuevo."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Istunto vanhentunut kohteelle %@. Kirjaudu sisään uudelleen."
          }
        },
        "fr" : {
          "stringUnit" : {
