    "error_login_expired %@" : {
      "comment" : "A title for a view that shows an error message when the user's login has expired. The argument is the account key of the user whose login has expired.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sessie is verval vir %@. Meld asseblief weer aan."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "انتهت صلاحية الجلسة لـ %@. يرجى تسجيل الدخول مرة أخرى."
          }
        },
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Сесията е изтекла за %@. Моля, впишете се отново."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La sessió ha caducat per a %@. Torneu a iniciar la sessió."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Relace vypršela pro %@. Přihlaste se prosím znovu."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sessionen er udløbet for %@. Log venligst ind igen."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sitzung für %@ abgelaufen. Bitte erneut anmelden."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Η συνεδρία έληξε για %@. Παρακαλώ συνδεθείτε ξανά."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Login expired for %@"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La sesión ha caducado para %@. Inicie sesión de nuevo."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Istunto vanhentunut kohteelle %@. Kirjaudu sisään uudelleen."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La session a expiré pour %@. Veuillez vous reconnecter."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "המושב פג עבור %@. אנא התחבר שוב."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A munkamenet lejárt %@ esetén. Kérjük, jelentkezzen be újra."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sessione scaduta per %@. Accedi di nuovo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ のセッションが期限切れです。再度サインインしてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@의 세션이 만료되었습니다. 다시 로그인하십시오."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
