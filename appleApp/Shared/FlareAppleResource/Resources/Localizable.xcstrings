        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Αυτός ο διακομιστής χρησιμοποιεί %@, το Flare θα εκτελείται σε κατάσταση συμβατότητας. Ορισμένες λειτουργίες ενδέχεται να μην λειτουργούν σωστά."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
