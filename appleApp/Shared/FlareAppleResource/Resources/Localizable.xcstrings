    "service_select_compatibility_warning" : {
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hierdie bediener gebruik %@, Flare sal in versoenbaarheidsmodus loop. Sommige kenmerke mag dalk nie reg werk nie."
          }
