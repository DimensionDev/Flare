    "Run a short rich-text sample through the current AI translation setup." : {
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hardloop 'n kort ryk-teks monster deur die huidige KI-vertaalopstelling."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "قم بتشغيل عينة نص منسق قصيرة من خلال إعداد ترجمة الذكاء الاصطناعي الحالي."
          }
        },
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Изпълнете кратка мостра с обогатен текст през текущата настройка за AI превод."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Executeu una mostra curta de text enriquit mitjançant la configuració actual de traducció d'IA."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spusťte krátký ukázkový formátovaný text aktuálním nastavením překladu AI."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kør en kort rich-text-prøve gennem den nuværende AI-oversættelsesopsætning."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Führen Sie eine kurze Rich-Text-Probe durch das aktuelle KI-Übersetzungssetup aus."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Εκτελέστε ένα σύντομο δείγμα εμπλουτισμένου κειμένου μέσω της τρέχουσας ρύθμισης μετάφρασης AI."
          }
