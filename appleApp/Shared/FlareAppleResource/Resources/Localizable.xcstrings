    "ai_config_post_insight_description" : {
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wanneer dit geaktiveer is, sal die AI Agent-funksie op die relevante plekke in die app verskyn wanneer n OpenAI-versoenbare model ingestel is."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "بعد التفعيل، ستظهر ميزة وكيل الذكاء الاصطناعي في المواضع المناسبة داخل التطبيق عند إعداد نموذج متوافق مع OpenAI."
          }
        },
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "След активиране функцията AI Agent ще се показва на съответните места в приложението, когато е настроен OpenAI-съвместим модел."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un cop activat, la funció AI Agent apareixerà als llocs corresponents de l’app quan s’hagi configurat un model compatible amb OpenAI."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Po povolení se funkce AI Agent zobrazí na příslušných místech v aplikaci, jakmile bude nastaven model kompatibilní s OpenAI."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Når funktionen er aktiveret, vises AI Agent de relevante steder i appen, når en OpenAI-kompatibel model er konfigureret."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nach der Aktivierung erscheint die AI-Agent-Funktion an den passenden Stellen in der App, sobald ein OpenAI-kompatibles Modell konfiguriert wurde."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Μόλις ενεργοποιηθεί, η λειτουργία AI Agent θα εμφανίζεται στα σχετικά σημεία της εφαρμογής όταν έχει ρυθμιστεί μοντέλο συμβατό με OpenAI."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Once enabled, the AI agent feature will appear in the relevant locations within the app when an OpenAI-compatible model has been configured."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kun toiminto on käytössä, AI Agent näkyy sovelluksen asiaankuuluvissa paikoissa, kun OpenAI-yhteensopiva malli on määritetty."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Une fois activée, la fonction AI Agent apparaîtra aux emplacements pertinents de l’app lorsqu’un modèle compatible OpenAI aura été configuré."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "לאחר ההפעלה, תכונת AI Agent תופיע במקומות הרלוונטיים באפליקציה כאשר מוגדר מודל תואם OpenAI."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Engedélyezés után az AI Agent funkció megjelenik az alkalmazás megfelelő helyein, ha OpenAI-kompatibilis modell van beállítva."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una volta abilitata, la funzione AI Agent apparirà nei punti pertinenti dell’app quando sarà configurato un modello compatibile con OpenAI."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "有効にすると、OpenAI互換モデルが設定されている場合に、アプリ内の関連する場所にAI Agent機能が表示されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "활성화하면 OpenAI 호환 모델이 설정된 경우 앱의 관련 위치에 AI Agent 기능이 표시됩니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Når den er aktivert, vises AI Agent-funksjonen på relevante steder i appen når en OpenAI-kompatibel modell er konfigurert."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Na inschakeling verschijnt de AI Agent-functie op de relevante plekken in de app wanneer een OpenAI-compatibel model is geconfigureerd."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Po włączeniu funkcja AI Agent pojawi się w odpowiednich miejscach aplikacji, gdy skonfigurowany będzie model zgodny z OpenAI."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Depois de ativada, a funcionalidade AI Agent aparecerá nos locais relevantes da app quando estiver configurado um modelo compatível com OpenAI."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Depois de ativada, a funcionalidade AI Agent aparecerá nos locais relevantes da app quando estiver configurado um modelo compatível com OpenAI."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "După activare, funcția AI Agent va apărea în locurile relevante din aplicație când este configurat un model compatibil OpenAI."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "После включения функция AI Agent появится в соответствующих местах приложения, если настроена модель, совместимая с OpenAI."
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Када се омогући, функција AI Agent ће се појавити на релевантним местима у апликацији када је подешен модел компатибилан са OpenAI."
