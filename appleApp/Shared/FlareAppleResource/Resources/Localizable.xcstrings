    "agent_chat_empty_description" : {
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vra oor tydlyne en plasings, of gebruik hierdie ruimte om n idee uit te werk."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اسأل عن الخطوط الزمنية والمنشورات، أو استخدم هذه المساحة لصياغة فكرة."
          }
        },
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Попитайте за хронологии и публикации или използвайте това място, за да оформите идея."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pregunta sobre línies de temps i publicacions, o fes servir aquest espai per donar forma a una idea."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zeptejte se na časové osy a příspěvky, nebo použijte tento prostor k rozpracování nápadu."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spørg om tidslinjer og opslag, eller brug dette område til at forme en idé."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Frage nach Timelines und Beiträgen oder nutze diesen Bereich, um eine Idee auszuarbeiten."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ρωτήστε για χρονολόγια και δημοσιεύσεις ή χρησιμοποιήστε αυτόν τον χώρο για να διαμορφώσετε μια ιδέα."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ask about timelines and posts, or use this space to shape an idea."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kysy aikajanoista ja julkaisuista tai käytä tätä tilaa idean muotoiluun."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Posez une question sur les fils et les publications, ou utilisez cet espace pour élaborer une idée."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "שאלו על צירי זמן ופוסטים, או השתמשו במרחב הזה כדי לעצב רעיון."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kérdezz idővonalakról és bejegyzésekről, vagy használd ezt a helyet egy ötlet kidolgozásához."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chiedi informazioni su timeline e post, oppure usa questo spazio per dare forma a un’idea."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "タイムラインや投稿について質問するか、このスペースでアイデアを形にできます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "타임라인과 게시물에 대해 묻거나 이 공간에서 아이디어를 정리하세요."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spør om tidslinjer og innlegg, eller bruk dette området til å forme en idé."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vraag naar tijdlijnen en berichten, of gebruik deze ruimte om een idee uit te werken."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zapytaj o osie czasu i posty albo użyj tego miejsca, aby rozwinąć pomysł."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pergunte sobre cronologias e publicações, ou use este espaço para dar forma a uma ideia."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pergunte sobre linha do tempos e publicações, ou use este espaço para dar forma a uma ideia."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Întreabă despre cronologii și postări sau folosește acest spațiu pentru a contura o idee."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Спросите о лентах и публикациях или используйте это место, чтобы оформить идею."
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Питајте о временским линијама и објавама или користите овај простор да обликујете идеју."
          }
        },
        "sv" : {
          "stringUnit" : {
