    "profile_blocked_gate_description" : {
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jy het hierdie profiel geblokkeer. Hul oortjies en tydlyn is versteek totdat jy kies om dit te wys."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لقد حظرت هذا الملف الشخصي. سيتم إخفاء تبويباته وخطه الزمني حتى تختار إظهارها."
          }
        },
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Блокирахте този профил. Разделите и хронологията му са скрити, докато не изберете да ги покажете."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Has bloquejat aquest perfil. Les seves pestanyes i la línia temporal resten ocultes fins que triïs mostrar-les."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tento profil jste zablokovali. Jeho karty a časová osa jsou skryté, dokud je nezvolíte zobrazit."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du har blokeret denne profil. Dens faner og tidslinje er skjult, indtil du vælger at vise dem."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du hast dieses Profil blockiert. Seine Tabs und Timeline bleiben verborgen, bis du sie anzeigen lässt."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Έχετε αποκλείσει αυτό το προφίλ. Οι καρτέλες και η χρονογραμμή του είναι κρυφές μέχρι να επιλέξετε να τις εμφανίσετε."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You blocked this user. Their tabs and timeline are hidden until you choose to show them."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Olet estänyt tämän profiilin. Sen välilehdet ja aikajana ovat piilossa, kunnes valitset niiden näyttämisen."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous avez bloqué ce profil. Ses onglets et son fil sont masqués jusqu’à ce que vous choisissiez de les afficher."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "חסמת את הפרופיל הזה. הכרטיסיות וציר הזמן שלו מוסתרים עד שתבחר להציג אותם."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Letiltottad ezt a profilt. A lapjai és az idővonala rejtve maradnak, amíg nem választod a megjelenítésüket."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hai bloccato questo profilo. Le sue schede e la timeline sono nascoste finché non scegli di mostrarle."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このプロフィールをブロックしています。表示を選ぶまで、タブとタイムラインは非表示になります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 프로필을 차단했습니다. 표시를 선택할 때까지 탭과 타임라인이 숨겨집니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du har blokkert denne profilen. Fanene og tidslinjen er skjult til du velger å vise dem."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Je hebt dit profiel geblokkeerd. De tabbladen en tijdlijn blijven verborgen totdat je ze weergeeft."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ten profil jest zablokowany. Jego karty i oś czasu są ukryte, dopóki nie wybierzesz ich wyświetlenia."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bloqueaste este perfil. Os separadores e a cronologia ficam ocultos até escolheres mostrá-los."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você bloqueou este perfil. As abas e a linha do tempo ficarão ocultas até você escolher mostrá-las."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ai blocat acest profil. Filele și cronologia sa sunt ascunse până când alegi să le afișezi."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вы заблокировали этот профиль. Его вкладки и лента скрыты, пока вы не решите их показать."
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Блокирали сте овај профил. Његове картице и временска линија су сакривене док не изаберете да их прикажете."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du har blockerat den här profilen. Dess flikar och tidslinje är dolda tills du väljer att visa dem."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bu profili engellediniz. Sekmeleri ve zaman akışı, göstermeyi seçene kadar gizlenir."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ви заблокували цей профіль. Його вкладки та стрічка приховані, доки ви не вирішите їх показати."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bạn đã chặn hồ sơ này. Các tab và dòng thời gian của họ sẽ bị ẩn cho đến khi bạn chọn hiển thị."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你已拉黑此用户。其标签页和时间线会被隐藏，直到你手动选择显示。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你已封鎖此使用者。其分頁和時間軸會被隱藏，直到你手動選擇顯示。"
          }
        }
      }
    },
