          "stringUnit" : {
            "state" : "translated",
            "value" : "האם אתה בטוח שברצונך לחסום משתמש זה?"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Biztosan le akarja tiltani ezt a felhasználót?"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sei sicuro di voler bloccare questo utente?"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このユーザーをブロックしてもよろしいですか？"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 사용자를 차단하시겠습니까?"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Er du sikker på at du vil blokkere denne brukeren?"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Weet je zeker dat je deze gebruiker wilt blokkeren?"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Czy na pewno chcesz zablokować tego użytkownika?"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tem a certeza de que pretende bloquear este utilizador?"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
