    "import_confirmation_message" : {
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dit sal data vanaf die gekose rugsteunlêer invoer. Bestaande rekords met ooreenstemmende ID's sal vervang word. Gaan voort?"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سيؤدي هذا إلى استيراد البيانات من ملف النسخة الاحتياطية المحدد. سيتم استبدال السجلات الموجودة ذات المعرفات المطابقة. هل تريد الاستمرار؟"
          }
        },
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Това ще импортира данни от избрания резервен файл. Съществуващите записи със съвпадащи идентификатори ще бъдат заменени. Продължаване?"
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Això importarà dades del fitxer de còpia de seguretat seleccionat. Els registres existents amb identificadors coincidents se substituiran. Vols continuar?"
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tímto se naimportují data z vybraného záložního souboru. Stávající záznamy se shodujícími se ID budou nahrazeny. Pokračovat?"
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dette importerer data fra den valgte sikkerhedskopifil. Eksisterende poster med matchende ID'er vil blive erstattet. Fortsæt?"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dies importiert Daten aus der ausgewählten Backup-Datei. Vorhandene Datensätze mit übereinstimmenden IDs werden ersetzt. Fortfahren?"
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Αυτό θα εισαγάγει δεδομένα από το επιλεγμένο αρχείο αντιγράφου ασφαλείας. Οι υπάρχουσες εγγραφές με αντίστοιχα ID θα αντικατασταθούν. Συνέχεια;"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This will import data from the selected backup file. Existing records with matching IDs will be replaced. Continue?"
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tämä tuo tiedot valitusta varmuuskopiotiedostosta. Aiemmat tietueet, joilla on sama tunniste, korvataan. Jatketaanko?"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ceci importera les données du fichier de sauvegarde sélectionné. Les enregistrements existants avec des ID correspondants seront remplacés. Continuer ?"
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "פעולה זו תייבא נתונים מקובץ הגיבוי שנבחר. רשומות קיימות עם מזהים תואמים יוחלפו. להמשיך?"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ez adatokat importál a kiválasztott biztonsági mentési fájlból. Az azonos azonosítóval rendelkező meglévő rekordok felülíródnak. Folytatod?"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Questo importerà i dati dal file di backup selezionato. I record esistenti con ID corrispondenti verranno sostituiti. Continuare?"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "選択したバックアップファイルからデータをインポートします。ID が一致する既存のレコードは上書きされます。続行しますか？"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "선택한 백업 파일에서 데이터를 가져옵니다. 일치하는 ID를 가진 기존 레코드는 교체됩니다. 계속하시겠습니까?"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dette vil importere data fra den valgte sikkerhetskopifilen. Eksisterende poster med samsvarende ID-er vil bli erstattet. Fortsette?"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hiermee worden gegevens uit het geselecteerde back-upbestand geïmporteerd. Bestaande records met overeenkomende ID's worden vervangen. Doorgaan?"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spowoduje to zaimportowanie danych z wybranego pliku kopii zapasowej. Istniejące rekordy o pasujących ID zostaną zastąpione. Kontynuować?"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isto irá importar dados do ficheiro de cópia de segurança selecionado. Os registos existentes com IDs correspondentes serão substituídos. Continuar?"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isso importará dados do arquivo de backup selecionado. Registros existentes com IDs correspondentes serão substituídos. Continuar?"
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aceasta va importa date din fișierul backup selectat. Înregistrările existente cu ID-uri identice vor fi înlocuite. Continui?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Это импортирует данные из выбранного файла резервной копии. Существующие записи с совпадающими ID будут заменены. Продолжить?"
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ово ће увести податке из изабране резервне копије. Постојећи записи са подударним ID-овима ће бити замењени. Наставити?"
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Detta importerar data från den valda säkerhetskopian. Befintliga poster med matchande ID kommer att ersättas. Vill du fortsätta?"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bu işlem, seçilen yedekleme dosyasından verileri içe aktaracaktır. Eşleşen kimliklere sahip mevcut kayıtlar değiştirilecektir. Devam edilsin mi?"
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Це імпортує дані з вибраного файлу резервної копії. Існуючі записи з відповідними ID будуть замінені. Продовжити?"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Thao tác này sẽ nhập dữ liệu từ tệp sao lưu đã chọn. Các bản ghi hiện có với ID trùng khớp sẽ bị thay thế. Tiếp tục?"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "这将从所选备份文件导入数据。具有匹配 ID 的现有记录将被替换。要继续吗？"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "這將從所選備份檔案匯入資料。現有具有相同 ID 的紀錄將被替換。是否繼續？"
          }
        }
      }
    },
