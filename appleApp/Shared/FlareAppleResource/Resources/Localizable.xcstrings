    "Are you sure you want to remove %@ from this device?" : {
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Is jy seker jy wil %@ van hierdie toestel verwyder?"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هل أنت متأكد أنك تريد إزالة %@ من هذا الجهاز؟"
          }
        },
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Сигурни ли сте, че искате да премахнете %@ от това устройство?"
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esteu segur que voleu eliminar %@ d'aquest dispositiu?"
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opravdu chcete odebrat %@ z tohoto zařízení?"
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Er du sikker på, at du vil fjerne %@ fra denne enhed?"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bist du sicher, dass du %@ von diesem Gerät entfernen möchtest?"
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Είστε βέβαιοι ότι θέλετε να καταργήσετε το %@ από αυτήν τη συσκευή;"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Are you sure you want to remove %@ from this device?"
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Haluatko varmasti poistaa kohteen %@ tästä laitteesta?"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Voulez-vous vraiment supprimer %@ de cet appareil ?"
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "האם אתה בטוח שברצונך להסיר את %@ ממכשיר זה?"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Biztosan el akarja távolítani a(z) %@ elemet erről az eszközről?"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sei sicuro di voler rimuovere %@ da questo dispositivo?"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このデバイスから%@を削除してもよろしいですか？"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 기기에서 %@을(를) 제거하시겠습니까?"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Er du sikker på at du vil fjerne %@ fra denne enheten?"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Weet je zeker dat je %@ van dit apparaat wilt verwijderen?"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Czy na pewno chcesz usunąć %@ z tego urządzenia?"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tem a certeza de que pretende remover %@ deste dispositivo?"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tem certeza de que deseja remover %@ deste dispositivo?"
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sigur dorești să elimini %@ de pe acest dispozitiv?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вы уверены, что хотите удалить %@ с этого устройства?"
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Да ли сте сигурни да желите да уклоните %@ са овог уређаја?"
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Är du säker på att du vill ta bort %@ från den här enheten?"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ öğesini bu cihazdan kaldırmak istediğinizden emin misiniz?"
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ви впевнені, що хочете видалити %@ з цього пристрою?"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bạn có chắc chắn muốn xóa %@ khỏi thiết bị này không?"
          }
        },
