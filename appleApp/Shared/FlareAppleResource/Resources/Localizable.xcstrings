    "report_user_description" : {
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Is jy seker jy wil hierdie gebruiker rapporteer?"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هل أنت متأكد أنك تريد الإبلاغ عن هذا المستخدم؟"
          }
        },
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Сигурни ли сте, че искате да докладвате този потребител?"
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Segur que vols informar sobre aquest usuari?"
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opravdu chcete tohoto uživatele nahlásit?"
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Er du sikker på, at du vil anmelde denne bruger?"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Möchtest du diesen Benutzer wirklich melden?"
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Είστε βέβαιοι ότι θέλετε να αναφέρετε αυτόν τον χρήστη;"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Are you sure you want to report this user?"
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Haluatko varmasti ilmiantaa tämän käyttäjän?"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Voulez-vous vraiment signaler cet utilisateur ?"
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "האם אתה בטוח שברצונך לדווח על משתמש זה?"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Biztosan jelenteni akarod ezt a felhasználót?"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sei sicuro di voler segnalare questo utente?"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "本当にこのユーザーを通報しますか？"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "정말로 이 사용자를 신고하시겠습니까?"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Er du sikker på at du vil rapportere denne brukeren?"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Weet je zeker dat je deze gebruiker wilt rapporteren?"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Czy na pewno chcesz zgłosić tego użytkownika?"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tem a certeza de que deseja denunciar este utilizador?"
          }
