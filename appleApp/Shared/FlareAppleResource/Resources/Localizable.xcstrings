    "ai_config_pre_translate_description" : {
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vertaal nuut gelaaide tydlyn- en profielinhoud in die agtergrond en kas die resultate. Dit kan 'n groot aantal tokens gebruik."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ترجمة محتوى الجدول الزمني والملف الشخصي الذي تم تحميله حديثًا في الخلفية وتخزين النتائج مؤقتًا. يمكن أن يستخدم هذا عددًا كبيرًا من الرموز."
          }
        },
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Превеждайте новозареденото съдържание на времевата линия и профила във фонов режим и кеширайте резултатите. Това може да използва голям брой токени."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tradueix el contingut de la línia de temps i del perfil acabat de carregar en segon pla i desa els resultats a la memòria cau. Això pot utilitzar un gran nombre de fitxes."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Přeložte nově načtený obsah časové osy a profilu na pozadí a uložte výsledky do mezipaměti. To může využívat velký počet tokenů."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oversæt nyligt indlæst tidslinje- og profilindhold i baggrunden, og cache resultateren. Dette kan bruge et stort antal tokens."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Neu geladene Timeline- und Profilinhalte im Hintergrund übersetzen und die Ergebnisse zwischenspeichern. Dies kann eine große Anzahl von Token verbrauchen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Μεταφράστε το περιεχόμενο της χρονολογικής σειράς και του προφίλ που φορτώθηκε πρόσφατα στο παρασκήνιο και αποθηκεύστε τα αποτελέσματα στην προσωρινή μνήμη. Αυτό μπορεί να χρησιμοποιήσει μεγάλο αριθμό κουπονιών."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Translate newly loaded timeline and profile content in the background and cache the results. This can use a large number of tokens."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Käännä vastaladattu aikajanan ja profiilin sisältö taustalla ja tallenna tulokset välimuistiin. Tämä voi kuluttaa suuren määrän tokeneita."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Traduire le contenu de la chronologie et du profil nouvellement chargés en arrière-plan et mettre les résultats en cache. Cela peut utiliser un grand nombre de jetons."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "תרגם תוכן ציר זמן ופרופיל שנטען לאחרונה ברקע ושמור את התוצאות במטמון. זה יכול להשתמש במספר רב של אסימונים."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Az újonnan betöltött idővonal- és profil tartalom fordítása a háttérben és az eredmények gyorsítótárazása. Ez nagy számú tokent használhat."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Traduci i contenuti della timeline e del profilo appena caricati in background e memorizza i risultati nella cache. Questo può consumare un gran numero di token."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "新しく読み込まれたタイムラインとプロフィールのコンテンツをバックグラウンドで翻訳し、結果をキャッシュします。これにより、大量のトークンが使用される可能性があります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "새로 로드된 타임라인 및 프로필 콘텐츠를 백그라운드에서 번역하고 결과를 캐시합니다. 이 기능은 많은 수의 토큰을 사용할 수 있습니다."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oversett nylig lastet tidslinje- og profilinnhold i bakgrunnen og lagre resultatene. Dette kan bruke mange tokens."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vertaal nieuw geladen tijdlijn- en profielinhoud op de achtergrond en cache de resultaten. Dit kan een groot aantal tokens verbruiken."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tłumacz nowo załadowaną zawartość osi czasu i profilu w tle i przechowuj wyniki w pamięci podręcznej. Może to zużywać dużą liczbę tokenów."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Traduzir o conteúdo da cronologia e do perfil recém-carregados em segundo plano e armazenar os resultados em cache. Isso pode usar um grande número de tokens."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Traduzir o conteúdo da cronologia e do perfil recém-carregados em segundo plano e armazenar os resultados em cache. Isso pode usar um grande número de tokens."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tradu conținutul cronologiei și profilului nou încărcat în fundal și stochează rezultatele în cache. Acest lucru poate utiliza un număr mare de jetoane."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Переводить недавно загруженный контент ленты и профиля в фоновом режиме и кэшировать результаты. Это может использовать большое количество токенов."
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Преводите новоучитани садржај временске линије и профила у позадини и кеширајте резултате. Ово може користити велики број токена."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Översätt nyligen laddat tidslinje- och profilinnehåll i bakgrunden och cachelagra resultaten. Detta kan använda ett stort antal tokens."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yeni yüklenen zaman akışı ve profil içeriğini arka planda çevirir ve sonuçları önbelleğe alır. Bu, çok sayıda jeton kullanabilir."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Перекладати нещодавно завантажений вміст стрічки та профілю у фоновому режимі та кешувати результати. Це може використовувати велику кількість токенів."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dịch nội dung dòng thời gian và hồ sơ mới tải ở chế độ nền và lưu kết quả vào bộ nhớ đệm. Việc này có thể sử dụng một lượng lớn token."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在后台翻译新加载的时间线和个人资料内容并缓存结果。这可能会使用大量 Token。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在背景翻譯新載入的時間線和個人資料內容並快取結果。這可能會使用大量 Token。"
          }
        }
      }
    },
