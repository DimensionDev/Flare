    "block_user_alert_message" : {
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Is jy seker jy wil hierdie gebruiker blokkeer?"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هل أنت متأكد أنك تريد حظر هذا المستخدم؟"
          }
        },
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Сигурни ли сте, че искате да блокирате този потребител?"
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esteu segur que voleu bloquejar aquest usuari?"
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opravdu chcete tohoto uživatele zablokovat?"
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Er du sikker på, at du vil blokere denne bruger?"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bist du sicher, dass du diesen Benutzer blockieren möchtest?"
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Είστε βέβαιοι ότι θέλετε να αποκλείσετε αυτόν τον χρήστη;"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Are you sure you want to block this user?"
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Haluatko varmasti estää tämän käyttäjän?"
          }
