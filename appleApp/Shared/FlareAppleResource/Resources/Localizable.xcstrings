          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вы уверены, что хотите заблокировать этого пользователя?"
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "translated",
