          }
        },
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Настройки на филтър за тукашната хронология"
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Configuració de filtre local per a la línia de temps"
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Místní nastavení filtru pro timeline"
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Skjul matchende indhold på tidslinjer, notifikationer og søgning"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Übereinstimmende Inhalte in Timelines, Benachrichtigungen und Suche ausblenden"
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Απόκρυψη περιεχομένου που ταιριάζει στις ροές, τις ειδοποιήσεις και την αναζήτηση"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hide matching content in timelines, notifications, and search"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ocultar contenido coincidente en las cronologías, notificaciones y búsquedas"
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Piilota vastaava sisältö aikajanoilla, ilmoituksissa ja haussa"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Masquer le contenu correspondant dans les fils, les notifications et la recherche"
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "הסתר תוכן תואם בציר הזמן, בהתראות ובחיפוש"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Egyező tartalmak elrejtése az idővonalakon, értesítésekben és a keresésben"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nascondi contenuti corrispondenti nelle timeline, notifiche e ricerca"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "タイムライン、通知、検索で一致するコンテンツを非表示にする"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "타임라인, 알림 및 검색에서 일치하는 콘텐츠 숨기기"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Skjul innhold som samsvarer i tidslinjer, varslinger og søk"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verberg overeenkomende inhoud in tijdlijnen, meldingen en zoekopdrachten"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ukrywaj pasujące treści na osiach czasu, w powiadomieniach i wynikach wyszukiwania"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
