    "tab_settings_merge_policy_desc" : {
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hoe plasings van verskillende bronne in gemengde tydlyne gekombineer word."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "كيفية دمج المنشورات من مصادر مختلفة في الجداول الزمنية المختلطة."
          }
        },
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Как се комбинират публикации от различни източници в смесени хронологии."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Com es combinen les publicacions de diferents fonts en línies de temps combinades."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jak se kombinují příspěvky z různých zdrojů v kombinovaných časových osách."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hvordan opslag fra forskellige kilder kombineres i blandede tidslinjer."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wie Beiträge aus verschiedenen Quellen in gemischten Timelines kombiniert werden."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Πώς συνδυάζονται αναρτήσεις από διαφορετικές πηγές σε μικτά χρονολόγια."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choose how items from each timeline are combined."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cómo se combinan las publicaciones de diferentes fuentes en líneas de tiempo mixtas."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Miten eri lähteistä tulevat julkaisut yhdistetään seka-aikajanoilla."
          }
        },
        "fr" : {
          "stringUnit" : {
