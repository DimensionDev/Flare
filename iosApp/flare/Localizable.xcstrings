    "misskey_achievement_notes100000_flavor" : {
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jy het seker baie om te sê."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "من المؤكد أن لديك الكثير لتقوله."
          }
        },
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Сигурно имате какво да кажете."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Segur que tens moltes coses a dir."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Určitě toho máte hodně co říct."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du har vist meget på hjerte."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du hast sicher viel zu sagen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Σίγουρα έχεις πολλά να πεις."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You sure have a lot to say."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seguro que tienes mucho que decir."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sinulla on varmasti paljon sanottavaa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous avez sûrement beaucoup de choses à dire."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "בטח יש לך הרבה מה להגיד."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Biztosan sok mondanivalód van."
