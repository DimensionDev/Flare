    "service_select_compatibility_warning" : {
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hierdie bediener gebruik %@, Flare sal in versoenbaarheidsmodus loop. Sommige kenmerke mag dalk nie reg werk nie."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يستخدم هذا الخادم %@، سيعمل Flare في وضع التوافق. قد لا تعمل بعض الميزات بشكل صحيح."
          }
        },
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Този сървър използва %@, Flare ще работи в режим на съвместимост. Някои функции може да не работят правилно."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aquest servidor utilitza %@, Flare s'executarà en mode de compatibilitat. Algunes funcions poden no funcionar correctament."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tento server používá %@, Flare poběží v režimu kompatibility. Některé funkce nemusí fungovat správně."
          }
        },
        "da" : {
