          "stringUnit" : {
            "state" : "translated",
            "value" : "Tämä laite ei tue vaihtoehtoisia sovelluskuvakkeita."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cet appareil ne prend pas en charge les icônes alternatives des applications."
          }
        },
