    "block_user_alert_message" : {
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Is jy seker jy wil hierdie gebruiker blokkeer?"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هل أنت متأكد أنك تريد حظر هذا المستخدم؟"
          }
        },
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Сигурни ли сте, че искате да блокирате този потребител?"
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esteu segur que voleu bloquejar aquest usuari?"
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opravdu chcete tohoto uživatele zablokovat?"
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Er du sikker på, at du vil blokere denne bruger?"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bist du sicher, dass du diesen Benutzer blockieren möchtest?"
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Είστε βέβαιοι ότι θέλετε να αποκλείσετε αυτόν τον χρήστη;"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Are you sure you want to block this user?"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Estás seguro de que quieres bloquear a este usuario?"
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Haluatko varmasti estää tämän käyttäjän?"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Voulez-vous vraiment bloquer cet utilisateur ?"
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "האם אתה בטוח שברצונך לחסום משתמש זה?"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Biztosan le akarja tiltani ezt a felhasználót?"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sei sicuro di voler bloccare questo utente?"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このユーザーをブロックしてもよろしいですか？"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 사용자를 차단하시겠습니까?"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Er du sikker på at du vil blokkere denne brukeren?"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Weet je zeker dat je deze gebruiker wilt blokkeren?"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Czy na pewno chcesz zablokować tego użytkownika?"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tem a certeza de que pretende bloquear este utilizador?"
          }
