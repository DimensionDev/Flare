    "local_filter_description" : {
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Plaaslike filter instellings vir tydlyn"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
