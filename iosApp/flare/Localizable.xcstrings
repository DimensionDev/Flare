          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ocultar conteúdo correspondente em linhas do tempo, notificações e pesquisa"
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ascunde conținutul corespunzător în cronologii, notificări și căutări"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Скрывать подходящий контент в лентах, уведомлениях и поиске"
