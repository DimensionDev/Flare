        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sicuramente hai molto da dire."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "言いたいことがたくさんあるんだね。"
