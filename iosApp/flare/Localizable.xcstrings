    "mute_user_alert_message" : {
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Is jy seker jy wil hierdie gebruiker stilmaak?"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هل أنت متأكد أنك تريد كتم صوت هذا المستخدم؟"
          }
        },
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Сигурни ли сте, че искате да заглушите този потребител?"
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Confirmes que vols silenciar aquest usuari?"
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opravdu chcete tohoto uživatele ztlumit?"
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Er du sikker på, at du vil ignorere denne bruger?"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bist du sicher, dass du diesen Benutzer stummschalten möchtest?"
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Είστε βέβαιοι ότι θέλετε να κάνετε σίγαση αυτού του χρήστη;"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Are you sure you want to mute this user?"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Estás seguro de que quieres silenciar a este usuario?"
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Haluatko varmasti mykistää tämän käyttäjän?"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Êtes-vous sûr de vouloir masquer cet utilisateur ?"
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "האם אתה בטוח שברצונך להשתיק משתמש זה?"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Biztosan némítani szeretné ezt a felhasználót?"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sei sicuro di voler silenziare questo utente?"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このユーザーをミュートしてもよろしいですか？"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 사용자를 뮤트하시겠습니까?"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Er du sikker på at du vil dempe denne brukeren?"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Weet je zeker dat je deze gebruiker wilt dempen?"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Czy na pewno chcesz wyciszyć tego użytkownika?"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tem a certeza que pretende silenciar este utilizador?"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tem certeza de que deseja silenciar este usuário?"
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sigur doriți să silențiați acest utilizator?"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вы уверены, что хотите скрыть этого пользователя?"
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Да ли сте сигурни да желите да утишате овог корисника?"
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Är du säker på att du vill tysta den här användaren?"
          }
        },
        "tr" : {
