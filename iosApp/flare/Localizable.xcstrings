        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "할 말이 정말 많으시네요."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du er sikker på at du har mye å si."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Je hebt vast veel te vertellen."
          }
        },
        "pl" : {
          "stringUnit" : {
