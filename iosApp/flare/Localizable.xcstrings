    "This device does not support alternate app icons." : {
      "comment" : "A message displayed when the user tries to change the app icon on a device that doesn't support it.",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هذا الجهاز لا يدعم أيقونات التطبيق البديلة."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toto zařízení nepodporuje alternativní ikony aplikace."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Denne enhed understøtter ikke alternative appikoner."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dieses Gerät unterstützt keine alternativen App-Symbole."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Αυτή η συσκευή δεν υποστηρίζει εναλλακτικά εικονίδια εφαρμογών."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Este dispositivo no soporta iconos de aplicaciones alternativos."
          }
        },
