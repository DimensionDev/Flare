    "tab_settings_enable_mixed_timeline_desc" : {
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gemengde tydlyn sal al die tab tydlyn resultate in 'n tab meng"
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سيتم خلط الخط الزمني المختلط بين جميع علامات التبويب في علامة تبويب واحدة"
          }
        },
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Обединената хронология ще обедини хронологиите от всички раздели в един раздел"
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La línia de temps mixta combinarà el resultat de totes les línies de temps en una fitxa"
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Směsná časová osa promíchá všechny panely s výsledkem jedné záložky"
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Blandet tidslinje vil blande alle faners tidslinje-resultater i én fane"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die gemischte Timeline mischt alle Tab-Timeline-Ergebnisse in einem Tab"
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Η μικτή ροή θα αναμίξει όλα τα αποτελέσματα των καρτελών σε μία καρτέλα"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mixed timeline will mix all tabs timeline result in one tab"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La cronología mixta mezclará todos los resultados de las pestañas en una sola"
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sekoitettu aikajana sekoittaa kaikkien välilehtien aikajanatulokset yhteen välilehteen"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La timeline mixte mélangera tous les résultats des onglets en un seul onglet"
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ציר זמן מעורב יערבב את כל תוצאות הלשוניות בלשונית אחת"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A vegyes idővonal az összes lap idővonalának eredményét egyetlen lapon vonja össze"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
